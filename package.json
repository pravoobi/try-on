{
  "name": "try-on",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node tools/copy-litert-wasm.mjs",
    "predev": "node tools/copy-litert-wasm.mjs",
    "prebuild": "node tools/copy-litert-wasm.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:all": "npm run build --workspaces --if-present && npm run test --workspaces --if-present && npm test",
    "typecheck": "tsc --noEmit",
    "fetch-models": "node tools/fetch-models.mjs",
    "fetch-test-photos": "node tools/fetch-test-photos.mjs"
  },
  "dependencies": {
    "@practics/tryon-core": "^0.1.0",
    "litert-react": "^0.1.0",
    "thin-plate-spline": "^0.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@litertjs/model-tester": "^2.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@webgpu/types": "^0.1.71",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
